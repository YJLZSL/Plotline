{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Plotline",
  "version": "2.7.0",
  "identifier": "com.plotline.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Plotline — 叙事创作工作台",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' blob:; connect-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self';"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/YJLZSL/Plotline/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1NDIwNDk4N0NBRTAxQzcKUldUSEFhNThtQVJDRlF0dk1EOGRRdzhUQkxKOWdCREpqdUpYMEVmMXF2bG1acTFSU3lodjVBNGoK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Plotline",
    "category": "Productivity",
    "shortDescription": "本地优先的叙事创作工作台",
    "longDescription": "面向小说作者、编剧和游戏叙事设计师的本地优先创作工作台，帮助用户通过可视化方式构建、组织和管理故事的时间线、角色关系和情节结构。",
    "copyright": "© 2026 Plotline Contributors",
    "homepage": "https://github.com/YJLZSL/Plotline",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "startMenuFolder": "Plotline",
        "compression": "lzma"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
