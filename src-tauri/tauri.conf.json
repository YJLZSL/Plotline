{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Plotline",
  "version": "0.1.0",
  "identifier": "com.plotline.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Plotline",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Plotline",
    "category": "Productivity",
    "shortDescription": "本地优先的叙事创作工作台",
    "longDescription": "面向小说作者、编剧和游戏叙事设计师的本地优先创作工作台，帮助用户通过可视化方式构建、组织和管理故事的时间线、角色关系和情节结构。",
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
